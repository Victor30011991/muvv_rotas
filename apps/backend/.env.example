# ================================
# MUVV ROTAS — Backend Environment
# ================================

# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados (PostgreSQL)
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/muvv_rotas"

# JWT
JWT_SECRET="muvv-rotas-jwt-secret-troque-em-producao"
JWT_REFRESH_SECRET="muvv-rotas-refresh-secret-troque-em-producao"
JWT_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# Google Maps (para calcular distâncias)
GOOGLE_MAPS_API_KEY=""

# PIX (Efí Bank — preencher depois do MVP)
EFI_CLIENT_ID=""
EFI_CLIENT_SECRET=""
EFI_SANDBOX=true
