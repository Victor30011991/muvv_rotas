{
  "name": "@muvv/backend",
  "version": "1.0.0",
  "description": "Muvv Rotas — API Backend",
  "main": "src/server.ts",
  "scripts": {
    "dev":          "tsx watch src/server.ts",
    "build":        "npx prisma generate",
    "start":        "npx tsx src/server.ts",
    "migrate":      "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed":         "tsx src/database/seed.ts",
    "reconciliar":  "tsx src/database/reconciliacao_financeira.ts",
    "migrar":       "tsx src/database/migrar_decimal.ts",
    "studio":       "prisma studio",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage":"vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.1",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.6.3",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
  }
}